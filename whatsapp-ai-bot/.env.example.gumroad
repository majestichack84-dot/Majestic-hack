# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Unique session ID (used for local auth state storage)
SESSION_ID=your-business-name

# Owner's phone number for pairing code (WhatsApp will send code to this number)
# Format: +254712345678 or 254712345678
OWNER_PHONE=+2547XXXXXXXX

# Optional: Port for server (default: 3000, only needed if deploying)
PORT=3000
